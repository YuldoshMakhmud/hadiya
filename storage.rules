rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Hamma o'qiy oladi
    match /{allPaths=**} {
      allow read: if true;
    }

    // Faqat login bo'lgan admin yoza oladi
    match /hadiya/{allPaths=**} {
      allow write: if request.auth != null
                   && request.auth.token.email != null;
    }
  }
}
